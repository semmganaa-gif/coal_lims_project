# ============================================================================
# COAL LIMS - Environment Configuration Template
# ============================================================================
#
# Энэ файлыг .env гэж хуулаад өөрийн тохиргоогоор солино уу:
# cp .env.example .env
#
# АНХААРУУЛГА: .env файлыг ХЭЗЭЭ Ч Git-д commit хийж болохгүй!
# ============================================================================

# ----------------------------------------------------------------------------
# APPLICATION SETTINGS
# ----------------------------------------------------------------------------

# Environment: development, production
FLASK_ENV=development

# Secret key - ЗААВАЛ өөрчлөх! (32+ тэмдэгт random string)
# Генерация: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-SECRET-KEY-AT-LEAST-32-CHARACTERS-LONG

# Debug mode (Production-д ЗААВАЛ False байх)
DEBUG=True

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------

# SQLite (Development)
DATABASE_URL=sqlite:///instance/coal_lims.db

# PostgreSQL (Production - зөвлөмж)
# DATABASE_URL=postgresql://username:password@localhost:5432/coal_lims

# MySQL (альтернатив)
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/coal_lims

# ----------------------------------------------------------------------------
# EMAIL CONFIGURATION
# ----------------------------------------------------------------------------

# SMTP Server
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True

# Email credentials (ХЭЗЭЭ Ч hardcode хийж болохгүй!)
# Gmail: https://myaccount.google.com/apppasswords хэсгээс App Password үүсгэнэ
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-specific-password

# Default sender
MAIL_DEFAULT_SENDER=Coal LIMS <your-email@example.com>

# ----------------------------------------------------------------------------
# SESSION CONFIGURATION
# ----------------------------------------------------------------------------

# Session cookie secure (Production-д True)
SESSION_COOKIE_SECURE=False

# HttpOnly cookie (XSS халдлагаас хамгаална)
SESSION_COOKIE_HTTPONLY=True

# SameSite cookie (CSRF халдлагаас хамгаална)
SESSION_COOKIE_SAMESITE=Lax

# Session lifetime (секундээр, default: 8 цаг)
PERMANENT_SESSION_LIFETIME=28800

# ----------------------------------------------------------------------------
# FILE UPLOAD CONFIGURATION
# ----------------------------------------------------------------------------

# Maximum upload size (bytes) - Default: 16MB
MAX_CONTENT_LENGTH=16777216

# Upload folder path
UPLOAD_FOLDER=instance/uploads/certificates

# Allowed file extensions (comma separated)
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,xlsx,xls

# ----------------------------------------------------------------------------
# SECURITY SETTINGS
# ----------------------------------------------------------------------------

# CSRF Protection (Production-д автоматаар True болно)
# Development-д хэрэгтэй бол False болгож болно
# WTF_CSRF_ENABLED=True

# CSRF token lifetime (секундээр)
WTF_CSRF_TIME_LIMIT=3600

# WebSocket CORS (Production-д тодорхой домэйн заах)
# Development-д автоматаар * болно
SOCKETIO_CORS_ORIGINS=https://your-domain.com

# Rate limiting (автоматаар идэвхтэй)
RATELIMIT_STORAGE_URL=memory://

# Login rate limit
LOGIN_RATE_LIMIT=5 per minute

# API rate limit
API_RATE_LIMIT=30 per minute

# ----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# ----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/app.log

# Audit log path
AUDIT_LOG_FILE=logs/audit.log

# Security log path
SECURITY_LOG_FILE=logs/security.log

# Log rotation (MB)
LOG_MAX_BYTES=10485760

# Log backup count
LOG_BACKUP_COUNT=10

# ----------------------------------------------------------------------------
# APPLICATION-SPECIFIC SETTINGS
# ----------------------------------------------------------------------------

# Timezone
TIMEZONE=Asia/Ulaanbaatar

# Date format
DATE_FORMAT=%Y-%m-%d
DATETIME_FORMAT=%Y-%m-%d %H:%M:%S

# Pagination
ITEMS_PER_PAGE=25
MAX_PAGE_SIZE=100

# Analysis settings
MAX_ANALYSIS_RESULTS=200
FLOAT_EPSILON=1e-9

# Sample settings
MIN_SAMPLE_WEIGHT=0.001
MAX_SAMPLE_WEIGHT=10000

# Bottle tolerance
BOTTLE_TOLERANCE=0.0015

# ----------------------------------------------------------------------------
# OPTIONAL: EXTERNAL SERVICES
# ----------------------------------------------------------------------------

# Redis (if using for caching/sessions)
# REDIS_URL=redis://localhost:6379/0

# Celery (if using for background tasks)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Sentry (error tracking)
# SENTRY_DSN=https://your-sentry-dsn

# ----------------------------------------------------------------------------
# DEVELOPMENT ONLY
# ----------------------------------------------------------------------------

# Flask debug toolbar
FLASK_DEBUG_TB_ENABLED=False

# SQL query logging
SQLALCHEMY_ECHO=False

# Profile performance
PROFILE=False

# ----------------------------------------------------------------------------
# PRODUCTION ONLY
# ----------------------------------------------------------------------------

# Force HTTPS redirects
# FORCE_HTTPS=True

# Trust proxy headers (if behind nginx/apache)
# PROXY_FIX=True

# ----------------------------------------------------------------------------
# BACKUP SETTINGS
# ----------------------------------------------------------------------------

# Backup directory
BACKUP_DIR=backups

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Auto backup enabled
AUTO_BACKUP_ENABLED=False

# Backup schedule (cron format: "0 2 * * *" = daily at 2 AM)
BACKUP_SCHEDULE=0 2 * * *

# ----------------------------------------------------------------------------
# ICPMS INTEGRATION
# ----------------------------------------------------------------------------

# ICPMS API URL (CHPP үйлдвэрийн удирдлагын систем)
ICPMS_API_URL=http://localhost:8000

# ICPMS API нэвтрэх мэдээлэл
ICPMS_USERNAME=lims_service
ICPMS_PASSWORD=your-icpms-password

# ICPMS API key (optional - хэрэв token ашиглахгүй бол)
# ICPMS_API_KEY=your-api-key

# Request timeout (секунд)
ICPMS_TIMEOUT=30

# ============================================================================
# END OF CONFIGURATION
# ============================================================================
